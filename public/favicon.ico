  /* Reset outer product wrapper to flex*/
  ul.products {
    display: flex !important;
    flex-wrap: wrap !important;
    padding: 0 !important;
    margin: 0 !important;
  }
  /* Force each product into 50% width */
  ul.products li.product {
    width: 50% !important;
    max-width: 50% !important;
    float: none !important;
    clear: none !important;
    margin: 0 !important;
    padding: 0 5px !important;
    box-sizing: border-box;
  }
  /* Remove potential container or column class constraints */
  .woocommerce ul.products li.product,
  .woocommerce-page ul.products li.product {
    width: 50% !important;
    max-width: 50% !important;
    margin: 0 !important;
  }
  /* Kill any internal flex-column blocking */
  .product-inner,
  .woocommerce ul.products li.product .product-inner {
    display: block !important;
    width: 100% !important;
  }
}
.woocommerce-info {
  display: none !important;
}
/* Hide Add to Cart buttons on archive (product list) */
ul.products li.product .button,
.woocommerce ul.products li.product .add_to_cart_button {
  display: none !important;
}
/* Hide Add to Cart button on single product page */
.single-product .cart,
.single-product form.cart {
  display: none !important;
}
/* Hide Shop Now buttons (if your theme adds them) */
.shop-now,
.button.shop-now,
a.button.shop-now {
  display: none !important;
}
/* Force capitalize product titles in shop */
.woocommerce ul.products li.product .woocommerce-loop-product__title,
.woocommerce-page ul.products li.product .woocommerce-loop-product__title,
.woocommerce-loop-product__title {
    text-transform: capitalize !important;
    font-variant: small-caps; /* optional, nice touch */
}
/* Force capitalize category titles */
.woocommerce ul.products li.product-category .woocommerce-loop-category__title,
.woocommerce-page ul.products li.product-category .woocommerce-loop-category__title,
.woocommerce-loop-category__title {
    text-transform: capitalize !important;
	
}
/* Make product prices bigger, regular weight, custom color */
.woocommerce ul.products li.product .price,
.woocommerce-page ul.products li.product .price {
    font-size: 23px;
    font-weight: 400;
    color: #7c7d86;
}
/* Hide Product ID only */
.product_meta span {
    display: none !important;
}
/* Show Category back */
.product_meta .posted_in {
    display: inline !important;
}
 /* Style ACF field below product title */
.dodatni-opis-proizvoda {
    font-size: 17px;           /* Your requested font size */
    color: #333;            /* Dark gray color */
    margin: 4px 0;             /* Some spacing above and below */
    font-weight: 400;       /* Regular font weight */
    line-height: 1.4;          /* Better readability */
    text-transform: none;      /* Ensure lowercase from PHP, not CSS */
    font-family: inherit;      /* Match theme font */
}
/* Hide the shop icon on the single product page */
body.single-product .sc_layouts_cart {
    display: none !important;
}
.elementor-widget-wrap .sc_layouts_item.elementor-widget-trx_sc_layouts_search {
    display: none !important;
}
/* Only for mobile devices (screens up to 768px wide) */
@media (max-width: 768px) {
  .woocommerce ul.products li.product-category img {
    margin-bottom: 1px !important; /* increase this value as needed */
  }
  .woocommerce ul.products li.product-category h2.woocommerce-loop-category__title {
    margin-bottom: 20px !important;
  }
}</style>
